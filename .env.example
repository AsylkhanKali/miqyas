# ╔═══════════════════════════════════════════════════════════════╗
# ║  MIQYAS — Environment Configuration                         ║
# ╚═══════════════════════════════════════════════════════════════╝
# Copy this file to .env and fill in your values.

# === Database ===
DATABASE_URL=postgresql+asyncpg://miqyas:miqyas_dev@localhost:5432/miqyas
DATABASE_URL_SYNC=postgresql://miqyas:miqyas_dev@localhost:5432/miqyas
POSTGRES_USER=miqyas
POSTGRES_PASSWORD=miqyas_dev
POSTGRES_DB=miqyas

# === Redis / Celery ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === App ===
SECRET_KEY=change-me-in-production
API_V1_PREFIX=/api/v1
PROJECT_NAME=MIQYAS
DEBUG=true

# === Storage ===
STORAGE_BACKEND=local  # "local" or "s3"
UPLOAD_DIR=./uploads
IFC_STORAGE_DIR=./uploads/ifc
VIDEO_STORAGE_DIR=./uploads/video
FRAME_STORAGE_DIR=./uploads/frames
REPORT_STORAGE_DIR=./uploads/reports

# === AWS (production file storage) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1
S3_BUCKET=miqyas-uploads

# === Procore Integration (Week 7) ===
PROCORE_CLIENT_ID=
PROCORE_CLIENT_SECRET=
PROCORE_REDIRECT_URI=http://localhost:3000/projects/{project_id}/integrations

# === Sentry Error Tracking (Week 7) ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# === Frontend Sentry (set in frontend/.env or build args) ===
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENV=development

# === Reverse Proxy / SSL (Phase 6) ===
DOMAIN=localhost  # Set to your domain for auto-TLS (e.g., miqyas.example.com)

# === Monitoring (Phase 6) ===
GRAFANA_USER=admin
GRAFANA_PASSWORD=miqyas

# === Gunicorn (production) ===
# GUNICORN_WORKERS=4
# LOG_LEVEL=info
