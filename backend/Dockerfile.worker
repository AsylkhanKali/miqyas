FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    libmagic1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements-worker.txt .
RUN pip install --no-cache-dir --timeout=300 -r requirements-worker.txt

COPY . .

RUN mkdir -p uploads/ifc uploads/video uploads/frames uploads/reports

CMD ["celery", "-A", "app.tasks.worker", "worker", "--loglevel=info", "--queues=default,parsing", "--concurrency=2"]
